{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "_meta": { "title": "_claude_inject_checkpoint" },
    "inputs": {
      "ckpt_name": "checkpoints/juggernautXL_v10RunDiffusion.safetensors"
    }
  },
  "2": {
    "class_type": "LoraLoader",
    "_meta": { "title": "_claude_inject_lora" },
    "inputs": {
      "lora_name": "loras/KaviB_v1_Prod.safetensors",
      "strength_model": 0.85,
      "strength_clip": 0.85,
      "model": ["1", 0],
      "clip": ["1", 1]
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "_claude_inject_prompt" },
    "inputs": {
      "text": "KaviB, photorealistic photograph, professional camera, shallow depth of field, natural lighting",
      "clip": ["2", 1]
    }
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "_claude_inject_negative" },
    "inputs": {
      "text": "blurry, extra fingers, malformed hands, deformed eyes, bad anatomy, duplicate person, watermark, text, low quality",
      "clip": ["2", 1]
    }
  },
  "5": {
    "class_type": "EmptyLatentImage",
    "_meta": { "title": "_claude_inject_latent" },
    "inputs": {
      "width": 832,
      "height": 1216,
      "batch_size": 1
    }
  },
  "6": {
    "class_type": "KSampler",
    "_meta": { "title": "_claude_inject_seed" },
    "inputs": {
      "seed": 42,
      "steps": 30,
      "cfg": 7.0,
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 1.0,
      "model": ["2", 0],
      "positive": ["3", 0],
      "negative": ["4", 0],
      "latent_image": ["5", 0]
    }
  },
  "7": {
    "class_type": "VAEDecode",
    "_meta": { "title": "VAE Decode" },
    "inputs": {
      "samples": ["6", 0],
      "vae": ["1", 2]
    }
  },
  "8": {
    "class_type": "FaceDetailer",
    "_meta": { "title": "Face Detailer — YOLOv8 (no insightface)" },
    "inputs": {
      "image": ["7", 0],
      "model": ["2", 0],
      "clip": ["2", 1],
      "vae": ["1", 2],
      "positive": ["3", 0],
      "negative": ["4", 0],
      "bbox_detector": {
        "class_type": "UltralyticsDetectorProvider",
        "inputs": { "model_name": "face_yolov8n.pt" }
      },
      "guide_size": 512,
      "guide_size_for": true,
      "max_size": 1024,
      "seed": 42,
      "steps": 20,
      "cfg": 7.0,
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 0.25,
      "feather": 5,
      "noise_mask": true,
      "force_inpaint": false,
      "bbox_threshold": 0.5,
      "bbox_dilation": 10,
      "bbox_crop_factor": 3.0,
      "sam_detection_hint": "center-1",
      "sam_dilation": 0,
      "sam_threshold": 0.93,
      "sam_bbox_expansion": 0,
      "sam_mask_hint_threshold": 0.7,
      "sam_mask_hint_use_negative": "False",
      "drop_size": 10,
      "wildcard": "",
      "cycle": 1
    }
  },
  "9": {
    "class_type": "SaveImage",
    "_meta": { "title": "Save Image" },
    "inputs": {
      "filename_prefix": "KaviB",
      "images": ["8", 0]
    }
  }
}
