{
  "1": {
    "_meta": {"title": "_claude_inject_checkpoint"},
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "Juggernaut-XL_v9_RunDiffusionPhoto_v2.safetensors"
    }
  },
  "2": {
    "_meta": {"title": "_claude_inject_lora"},
    "class_type": "LoraLoader",
    "inputs": {
      "model": ["1", 0],
      "clip": ["1", 1],
      "lora_name": "AnanyaAI_v1_Prod.safetensors",
      "strength_model": 0.85,
      "strength_clip": 0.85
    }
  },
  "3": {
    "_meta": {"title": "_claude_inject_prompt"},
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "AnanyaAI, photorealistic, 8k, sharp focus",
      "clip": ["2", 1]
    }
  },
  "4": {
    "_meta": {"title": "_claude_inject_negative"},
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "worst quality, low quality, blurry, deformed, ugly, extra limbs, bad anatomy, watermark",
      "clip": ["2", 1]
    }
  },
  "5": {
    "_meta": {"title": "_claude_inject_latent"},
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": 896,
      "height": 1152,
      "batch_size": 1
    }
  },
  "13": {
    "class_type": "IPAdapterModelLoader",
    "_meta": {"title": "IPAdapter Model Loader"},
    "inputs": {
      "ipadapter_file": "sdxl_models\\ip-adapter-plus-face_sdxl_vit-h.safetensors"
    }
  },
  "14": {
    "class_type": "CLIPVisionLoader",
    "_meta": {"title": "CLIP Vision Loader"},
    "inputs": {
      "clip_name": "CLIP-ViT-H-14-laion2B-s32B-b79K.safetensors"
    }
  },
  "15": {
    "class_type": "LoadImage",
    "_meta": {"title": "_claude_inject_ipadapter_image"},
    "inputs": {
      "image": "face_ref.png",
      "upload": "image"
    }
  },
  "16": {
    "class_type": "IPAdapterAdvanced",
    "_meta": {"title": "_claude_inject_ipadapter_strength"},
    "inputs": {
      "model": ["2", 0],
      "ipadapter": ["13", 0],
      "image": ["15", 0],
      "clip_vision": ["14", 0],
      "weight": 0.5,
      "weight_type": "linear",
      "combine_embeds": "concat",
      "start_at": 0.15,
      "end_at": 1.0,
      "embeds_scaling": "V only"
    }
  },
  "17": {
    "_meta": {"title": "_claude_inject_controlnet"},
    "class_type": "ControlNetLoader",
    "inputs": {
      "control_net_name": "control-lora-openposeXL2-rank256.safetensors"
    }
  },
  "18": {
    "_meta": {"title": "_claude_inject_controlnet_image"},
    "class_type": "LoadImage",
    "inputs": {
      "image": "pose_ref.png",
      "upload": "image"
    }
  },
  "19": {
    "_meta": {"title": "ControlNet Apply"},
    "class_type": "ControlNetApply",
    "inputs": {
      "conditioning": ["3", 0],
      "control_net": ["17", 0],
      "image": ["18", 0],
      "strength": 0.8
    }
  },
  "6": {
    "_meta": {"title": "_claude_inject_seed"},
    "class_type": "KSampler",
    "inputs": {
      "model": ["16", 0],
      "positive": ["19", 0],
      "negative": ["4", 0],
      "latent_image": ["5", 0],
      "seed": 0,
      "steps": 30,
      "cfg": 7.0,
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 1.0
    }
  },
  "7": {
    "_meta": {"title": "VAE Decode"},
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["6", 0],
      "vae": ["1", 2]
    }
  },
  "10": {
    "_meta": {"title": "Save Image"},
    "class_type": "SaveImage",
    "inputs": {
      "images": ["7", 0],
      "filename_prefix": "ananya"
    }
  }
}
